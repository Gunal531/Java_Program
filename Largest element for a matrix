public class Matrixsum {
    public static void main(String[] args) {

        int[][] a = {
            {19, 21},
            {35, 43},
            {41, 62}
        };
        int largest=a[0][0];
        
        for(int i=0;i<a.length;i++){
            for(int j=0;j<a[i].length;j++){
                if(a[i][j]>largest){
                    largest=a[i][j];
                }
            }
            System.out.println(largest+" ");
            
        }
        
    }
}
