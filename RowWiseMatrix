public class RowWiseMatrix {
    public static void main(String[] args) {

        int[][] a = {
            {19, 21},
            {35, 43},
            {41, 62}
        };
        
        for(int i=0;i<a.length;i++){
            int sum=0;
            for(int j=0;j<a[i].length;j++){
                sum+=a[i][j];
                }
                System.out.println(sum+" ");
            }   
    }
}
